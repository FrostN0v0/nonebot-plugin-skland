<!DOCTYPE html>
<html lang="zh-CN">

<head>
  <meta charset="UTF-8">
  <title>Help</title>
  <style>
    {% include "index.css" %}

    .menu-container {
      margin: 25px;
      padding: 25px;
      border-radius: 20px;
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .menu-title {
      font-size: 30px;
      color: #fff;
      margin-bottom: 24px;
      font-weight: bold;
      letter-spacing: 3px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .menu-title::before {
      content: "";
      width: 6px;
      height: 30px;
      background: #ffd666;
      border-radius: 3px;
    }

    /* 三列布局核心 */
    .menu-columns {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      align-items: start;
    }

    .column-stack {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    /* 菜单项目样式 */
    .menu-item {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 12px 16px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.07);
      border: 1px solid rgba(255, 255, 255, 0.05);
      min-height: 60px; /* 保证高度整齐 */
    }

    .menu-name {
      color: #ffd666; /* 名字用亮色，易于寻找 */
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 4px;
    }

    .menu-desc {
      color: rgba(255, 255, 255, 0.65);
      font-size: 12px;
      line-height: 1.4;
      /* 限制描述行数，防止过长撑乱布局 */
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>
</head>

<body>
  <div class="relative w-[706px] h-[1160px] bg-cover bg-center bg-no-repeat"
       style="background-image: url({{ background_image }})">

    <div class="w-full flex justify-center pt-6">
      <span class="text-white/40 font-[Bender] tracking-widest text-center text-[10px] uppercase">
        Skland Assistant Protocol // Help Terminal
      </span>
    </div>

    <div class="menu-container">
      <div class="menu-title">📖 指令手册</div>

      <div class="menu-columns">
        
        <div class="column-stack">
          {% for item in column1 %}
          <div class="menu-item">
            <div class="menu-name">{{ item.name }}</div>
            <div class="menu-desc">{{ item.desc }}</div>
          </div>
          {% endfor %}
        </div>

        <div class="column-stack">
          {% for item in column2 %}
          <div class="menu-item">
            <div class="menu-name">{{ item.name }}</div>
            <div class="menu-desc">{{ item.desc }}</div>
          </div>
          {% endfor %}
        </div>

        <div class="column-stack">
          {% for item in column3 %}
          <div class="menu-item">
            <div class="menu-name">{{ item.name }}</div>
            <div class="menu-desc">{{ item.desc }}</div>
          </div>
          {% endfor %}
        </div>

      </div>
    </div>

    <div class="absolute bottom-6 w-full px-12 opacity-30">
        <div class="h-[1px] bg-white w-full"></div>
    </div>

  </div>
</body>

</html>