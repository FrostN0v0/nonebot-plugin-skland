{% from 'operator_roster_macros.html.jinja2' import operator_roster_card, operator_roster_filters, operator_roster_header %}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ props.title }}</title>
  <style>
    {% include "index.css" %}
  </style>
</head>
<body class="m-0 bg-[#111111] font-sans">
  <main
    class="relative box-border w-[706px] overflow-hidden bg-[#3F3F3F] bg-cover bg-center bg-no-repeat text-white"
    {% if background_image %}style="background-image: url('{{ background_image }}');"{% endif %}
  >
    {% if background_image %}
    <div class="pointer-events-none absolute top-0 right-0 left-0 h-[146px] bg-[#363636]/30 backdrop-blur-[2px]"></div>
    <div class="pointer-events-none absolute top-[146px] right-0 bottom-0 left-0 bg-[#363636]/30 backdrop-blur-[6px]"></div>
    {% endif %}

    {{ operator_roster_header(props.status) }}
    {{ operator_roster_filters(props.tags) }}

    {% if props.cards %}
    <section
      class="relative z-10 grid grid-cols-4 content-start justify-start gap-[30px] px-[30px]"
    >
      {% for card in props.cards %}
      {{ operator_roster_card(card) }}
      {% endfor %}
    </section>
    {% else %}
    <div class="relative z-10 px-[30px] py-16 text-center font-[Bender] text-sm text-white/70">
      No operators matched current filters.
    </div>
    {% endif %}

    <footer class="relative z-10 flex items-start justify-center pt-12 pb-11 font-[Bender] text-xs leading-[14px] text-[#f0f0f0]/80">
      Generated by nonebot-plugin-skland
    </footer>
  </main>
</body>
</html>
