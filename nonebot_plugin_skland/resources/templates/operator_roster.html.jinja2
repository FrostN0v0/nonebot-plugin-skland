<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }}</title>
  <style>
    {% include "index.css" %}
  </style>
</head>
<body class="m-0 bg-[#f8f9fa] text-[#202122] font-sans">
  <main
    class="box-border w-[var(--page-width)] px-[var(--side-pad)] pt-4 pb-6"
    style="--page-width: {{ page_width }}px; --side-pad: {{ side_pad }}px;"
  >
    <header class="mb-3">
      <h1 class="m-0 mb-1 text-xl leading-tight font-bold">{{ title }}</h1>
      <p class="m-0 text-xs text-[#54595d]">{{ subtitle }}</p>
    </header>

    {% if cards %}
    <section
      class="grid content-start justify-start gap-x-[var(--col-gap)] gap-y-[var(--row-gap)] [grid-template-columns:repeat(var(--cols),var(--unit-width))]"
      style="--cols: {{ cols }}; --unit-width: {{ unit_w }}px; --col-gap: {{ col_gap }}px; --row-gap: {{ row_gap }}px;"
    >
      {% for card in cards %}
      <article
        class="flex w-[var(--unit-width)] items-start gap-[var(--card-skill-gap)]"
        style="--unit-width: {{ unit_w }}px; --card-skill-gap: {{ card_skill_gap }}px;"
      >
        <div
          class="h-[var(--card-height)] w-[var(--card-width)] shrink-0"
          style="--card-width: {{ card_w }}px; --card-height: {{ card_h }}px;"
        >
          <div
            class="relative block h-[250px] w-[120px] overflow-hidden bg-transparent font-sans leading-none [filter:drop-shadow(0_0_7px_rgba(0,0,0,0.7))] [zoom:var(--card-scale)]{% if not card.owned %} opacity-[0.42] grayscale{% endif %}"
            style="--card-scale: {{ card_scale }};"
          >
            <div class="absolute top-0"><img class="w-[70px]" src="{{ card.uh }}" alt="" /></div>
            <div class="absolute top-0"><img class="w-[70px]" src="{{ card.uhs }}" alt="" /></div>
            <div class="absolute top-[5px] left-[3px] z-[1]"><img class="w-[25px]" src="{{ card.class_icon }}" alt="" /></div>
            <div class="absolute top-0 left-[30px] z-[2]"><img class="h-[18px]" src="{{ card.rarity_icon }}" alt="" /></div>
            <div class="absolute bottom-0 left-0 z-[2]"><img class="w-[120px]" src="{{ card.lh }}" alt="" /></div>
            <div class="absolute bottom-[25px] left-[3px] z-[1]"><img class="w-[110px]" src="{{ card.light }}" alt="" /></div>
            <div class="absolute bottom-[7px] left-[3px] z-0"><img class="w-[110px]" src="{{ card.bg }}" alt="" /></div>
            <div class="absolute right-[7px] bottom-[29px] z-0">
              <img class="max-w-none origin-bottom-right scale-[0.61111]" src="{{ card.portrait }}" alt="{{ card.name }}" />
            </div>
            <div class="absolute bottom-[7px] left-[3px] z-[1] h-[30px] w-[80px] bg-[#2c2c2c]"></div>
            {% if card.logo %}
            <div class="absolute bottom-[13px] left-[2px] z-[3]"><img class="w-[50px]" src="{{ card.logo }}" alt="" /></div>
            {% endif %}
            {% if card.owned and card.meta_text %}
            <div class="absolute right-[2px] bottom-[38px] left-[48px] z-[3] overflow-hidden text-center text-base leading-[1.1] font-bold text-ellipsis whitespace-nowrap text-white [text-shadow:0_0_8px_#000,0_1px_2px_#000]">
              <span class="inline-flex max-w-full items-center justify-center gap-[3px]">
                {% if card.elite %}<img class="block h-auto w-7 shrink-0 object-contain object-center" src="{{ card.elite }}" alt="" />{% endif %}
                <span class="min-w-0 overflow-hidden text-ellipsis">{{ card.meta_text }}</span>
              </span>
            </div>
            {% endif %}
            <div class="absolute right-[2px] bottom-[6px] left-[48px] z-[3] m-0 max-h-[34px] overflow-hidden p-0 text-center text-sm leading-[1.15] text-white [display:-webkit-box] [-webkit-box-orient:vertical] [-webkit-line-clamp:2] [text-shadow:0_0_10px_#000] break-all">
              {{ card.name }}
            </div>
          </div>
        </div>

        <aside
          class="box-border flex h-[var(--card-height)] w-[var(--skill-rail-width)] shrink-0 flex-col items-center justify-between py-1{% if not card.owned %} opacity-40 grayscale{% endif %}"
          style="--card-height: {{ card_h }}px; --skill-rail-width: {{ skill_rail_w }}px;"
        >
          <div class="flex w-full flex-col items-center gap-1.5">
            {% for module in card.modules %}
            <div class="relative size-12 shrink-0 overflow-hidden rounded-[5px] bg-[#2a2a2a] outline-[1px] outline-white/45{% if module.selected %} shadow-[0_0_6px_rgba(127,215,255,0.65)] outline-2 outline-[#7fd7ff]{% endif %}{% if module.locked %} brightness-[0.42] saturate-[0.35] outline-white/20{% endif %}">
              <img class="block size-full bg-[#1a1a1a] object-contain" src="{{ module.icon }}" alt="" />
              {% if not module.locked %}
              <div class="pointer-events-none absolute top-0 left-0 z-[3] flex size-[18px] items-center justify-center bg-[#080808]/90 text-[11px] leading-none font-bold text-white">{{ module.level }}</div>
              {% endif %}
            </div>
            {% endfor %}
          </div>

          <div class="flex w-full flex-col items-center gap-1.5">
            {% for skill in card.skills %}
            <div class="relative size-12 shrink-0 overflow-hidden rounded-[5px] bg-[#2a2a2a] outline-[1px] outline-white/45{% if skill.mastered %} shadow-[0_0_6px_rgba(127,215,255,0.65)] outline-2 outline-[#7fd7ff]{% endif %}">
              <img class="block size-full bg-[#1a1a1a] object-contain" src="{{ skill.icon }}" alt="" />
              <div class="pointer-events-none absolute top-0 left-0 z-[3] size-[18px] bg-[#080808]/90">
                {% if skill.specialize_level > 0 %}
                <span class="absolute top-[2.5px] left-1/2 size-[4.5px] -translate-x-1/2 rounded-full{% if skill.specialize_level >= 1 %} bg-white{% else %} bg-white/30{% endif %}"></span>
                <span class="absolute top-[9.5px] left-[28%] size-[4.5px] -translate-x-1/2 rounded-full{% if skill.specialize_level >= 2 %} bg-white{% else %} bg-white/30{% endif %}"></span>
                <span class="absolute top-[9.5px] left-[72%] size-[4.5px] -translate-x-1/2 rounded-full{% if skill.specialize_level >= 3 %} bg-white{% else %} bg-white/30{% endif %}"></span>
                {% elif card.owned and skill.main_skill_lvl > 0 %}
                <span class="flex size-full items-center justify-center text-[11px] leading-none font-bold text-white">{{ skill.main_skill_lvl }}</span>
                {% else %}
                <span class="absolute top-[2.5px] left-1/2 size-[4.5px] -translate-x-1/2 rounded-full bg-white/30"></span>
                <span class="absolute top-[9.5px] left-[28%] size-[4.5px] -translate-x-1/2 rounded-full bg-white/30"></span>
                <span class="absolute top-[9.5px] left-[72%] size-[4.5px] -translate-x-1/2 rounded-full bg-white/30"></span>
                {% endif %}
              </div>
            </div>
            {% endfor %}
          </div>
        </aside>
      </article>
      {% endfor %}
    </section>
    {% else %}
    <div class="px-3 py-10 text-center text-sm text-[#54595d]">No operators matched current filters.</div>
    {% endif %}
  </main>
</body>
</html>
